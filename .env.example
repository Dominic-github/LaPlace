# =====================================
# LaPlace - Environment Configuration
# =====================================

# Application
NODE_ENV=development
APP_NAME=LaPlace
APP_URL=http://localhost:8901

# Ports
SERVER_PORT=7201
ADMIN_PORT=7202
CLIENT_PORT=7203

# Database (MySQL)
DB=mysql
DB_HOST=mysql
DB_PORT=7205
DB_USERNAME=laplace
DB_PASSWORD=123456
DB_NAME=laplace_db

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Email Configuration (Gmail)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@laplace.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ENCRYPTION=tls

# Frontend URLs
VITE_API_URL=http://localhost:8901
NEXT_PUBLIC_API_URL=http://localhost:8901

# Socket.io
SOCKET_CORS_ORIGIN=http://localhost:8902,http://localhost:8903

# Upload
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_FILE_TYPES=application/pdf

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Security
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:8902,http://localhost:8903
