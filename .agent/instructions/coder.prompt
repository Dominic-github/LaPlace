## Admin Patterns (Refine + Ant Design)

### Resource List Page

```tsx
// pages/listings/list.tsx
import { List, useTable, EditButton, ShowButton, DeleteButton } from "@refinedev/antd";
import { Table, Tag, Space } from "antd";

export const ListingList = () => {
  const { tableProps } = useTable({
    resource: "listings",
    sorters: { initial: [{ field: "createdAt", order: "desc" }] },
  });

  return (
    <List>
      <Table {...tableProps} rowKey="id">
        <Table.Column dataIndex="title" title="Tiêu đề" />
        <Table.Column dataIndex="price" title="Giá thuê"
          render={(value) => `${value?.toLocaleString('vi-VN')}đ/tháng`}
        />
        <Table.Column dataIndex="status" title="Trạng thái"
          render={(value) => (
            <Tag color={value === 'available' ? 'green' : value === 'occupied' ? 'blue' : 'orange'}>
              {value}
            </Tag>
          )}
        />
        <Table.Column title="Thao tác"
          render={(_, record) => (
            <Space>
              <EditButton hideText size="small" recordItemId={record.id} />
              <ShowButton hideText size="small" recordItemId={record.id} />
              <DeleteButton hideText size="small" recordItemId={record.id} />
            </Space>
          )}
        />
      </Table>
    </List>
  );
};
```

### Resource Create/Edit

```tsx
// pages/listings/create.tsx
import { Create, useForm } from "@refinedev/antd";
import { Form, Input, InputNumber, Select } from "antd";

export const ListingCreate = () => {
  const { formProps, saveButtonProps } = useForm();

  return (
    <Create saveButtonProps={saveButtonProps}>
      <Form {...formProps} layout="vertical">
        <Form.Item label="Tiêu đề" name="title" rules={[{ required: true }]}>
          <Input />
        </Form.Item>
        <Form.Item label="Giá thuê/tháng" name="price" rules={[{ required: true }]}>
          <InputNumber style={{ width: '100%' }} formatter={v => `${v}`.replace(/\B(?=(\d{3})+(?!\d))/g, ',')} />
        </Form.Item>
        <Form.Item label="Trạng thái" name="status" initialValue="available">
          <Select options={[
            { label: 'Còn trống', value: 'available' },
            { label: 'Đã thuê', value: 'occupied' },
            { label: 'Bảo trì', value: 'maintenance' },
          ]} />
        </Form.Item>
      </Form>
    </Create>
  );
};
```

