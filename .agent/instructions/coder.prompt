## Client Patterns (Next.js 15 + Tailwind)

### Server Component (Data Fetching)

```tsx
// app/(public)/phong-tro/[slug]/page.tsx
import { notFound } from 'next/navigation';

async function getAccommodation(slug: string) {
  const res = await fetch(`${process.env.NEXT_PUBLIC_API_URL}/api/accommodations/${slug}`, {
    next: { revalidate: 3600 }
  });
  if (!res.ok) return null;
  return res.json();
}

export default async function AccommodationPage({
  params
}: {
  params: { slug: string }
}) {
  const { data } = await getAccommodation(params.slug);
  if (!data) notFound();

  return <AccommodationDetail accommodation={data} />;
}
```

### Client Component (Interactive)

```tsx
'use client';

import { useState } from 'react';

export function BookingForm({ accommodationId }: { accommodationId: number }) {
  const [loading, setLoading] = useState(false);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setLoading(true);
    // Booking API call
    setLoading(false);
  };

  return (
    <form onSubmit={handleSubmit} className="bg-white rounded-xl p-6 shadow-lg">
      <h3 className="text-xl font-semibold text-gray-900 mb-4">Đặt phòng</h3>
      <button
        type="submit"
        disabled={loading}
        className="w-full bg-primary text-white py-3 rounded-lg font-medium
                   hover:bg-primary-dark disabled:opacity-50 transition-colors"
      >
        {loading ? 'Đang xử lý...' : 'Đặt phòng ngay'}
      </button>
    </form>
  );
}
```

