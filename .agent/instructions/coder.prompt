## Server Patterns (Express + Sequelize)

### Controller Pattern

```javascript
// controlers/accommodationController.js  (⚠️ typo "controlers" là tên folder thực tế)
const { Accommodation, Facility } = require('../models');

exports.getAll = async (req, res) => {
  try {
    const { page = 1, limit = 10, status, search } = req.query;
    const where = {};
    if (status) where.status = status;
    if (search) where.title = { [Op.like]: `%${search}%` };

    const { rows: data, count: total } = await Accommodation.findAndCountAll({
      where,
      include: [{ model: Facility, as: 'facilities' }],
      limit: parseInt(limit),
      offset: (parseInt(page) - 1) * parseInt(limit),
      order: [['createdAt', 'DESC']],
    });

    res.json({
      success: true,
      data,
      meta: { total, page: parseInt(page), limit: parseInt(limit) }
    });
  } catch (error) {
    res.status(500).json({ success: false, message: error.message });
  }
};
```

### Route Pattern

```javascript
// routes/accommodation/index.js
const router = require('express').Router();
const controller = require('../../controlers/accommodation');
const { authenticate, authorize } = require('../../middlewares/authMiddleware');

router.get('/', controller.getAll);
router.get('/:id', controller.getById);
router.post('/', authenticate, authorize('admin'), controller.create);
router.put('/:id', authenticate, authorize('admin'), controller.update);
router.delete('/:id', authenticate, authorize('admin'), controller.delete);

module.exports = router;
```

