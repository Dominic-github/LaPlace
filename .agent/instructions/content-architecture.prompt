## SEO Integration

### Metadata

```tsx
// app/phong-tro/[slug]/page.tsx
export async function generateMetadata({ params }): Promise<Metadata> {
  const accommodation = await getAccommodation(params.slug);
  return {
    title: accommodation.title + ' - LaPlace',
    description: `Cho thuê ${accommodation.type} tại ${accommodation.address}. Giá ${formatPrice(accommodation.price)}/tháng.`,
    openGraph: {
      images: accommodation.images,
    }
  };
}
```

### Structured Data

```tsx
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: accommodation.title,
  image: accommodation.images,
  address: {
    '@type': 'PostalAddress',
    addressLocality: accommodation.district,
    addressRegion: accommodation.province,
    addressCountry: 'VN',
  },
  priceRange: formatPrice(accommodation.price) + '/tháng',
};
```

